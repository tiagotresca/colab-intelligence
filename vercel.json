{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "mkdir -p public",
  "outputDirectory": "public",
  "crons": [
    {
      "path": "/api/ingest/shopify",
      "schedule": "0 5 * * *"
    },
    {
      "path": "/api/ingest/meta-ads",
      "schedule": "0 6 * * *"
    }
  ],
  "functions": {
    "api/ingest/**/*.ts": {
      "maxDuration": 300
    },
    "api/dashboard.ts": {
      "maxDuration": 300
    }
  },
  "rewrites": [
    { "source": "/dashboard", "destination": "/api/dashboard" }
  ]
}
