# Supabase (deste projecto — separado do work.colab)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Token partilhado para autenticar requests ao MCP server.
# Gera um secret aleatório (ex: openssl rand -hex 32) e mete o mesmo
# valor no work.colab quando o agente lá consumir este MCP.
MCP_SHARED_TOKEN=

# Anthropic (agente autónomo da Colab — server-side, não dos users)
ANTHROPIC_API_KEY=

# work.colab MCP — para o agente autónomo daqui criar drafts de tarefas no dashboard
WORKCOLAB_MCP_URL=
WORKCOLAB_MCP_TOKEN=

# Embedding provider (Fase 2)
VOYAGE_API_KEY=

# Acesso read-only à Supabase do work.colab — fonte de credenciais
# Shopify (e futuramente Meta/Klaviyo/etc) por empresa. Source of
# truth para credenciais é o work.colab; aqui só lemos.
# Os valores são os mesmos que VITE_SUPABASE_URL e a service-role key
# no projecto Vercel do work.colab.
WORKCOLAB_SUPABASE_URL=
WORKCOLAB_SUPABASE_SERVICE_ROLE_KEY=

# Secret partilhado entre o Vercel cron e os endpoints de ingest.
# Vercel envia automaticamente Authorization: Bearer ${CRON_SECRET}
# nos crons. Para triggers manuais (staging) usa o mesmo header.
# Gera com: openssl rand -hex 32
CRON_SECRET=
