# Supabase (deste projecto — separado do work.colab)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Token partilhado para autenticar requests ao MCP server.
# Gera um secret aleatório (ex: openssl rand -hex 32) e mete o mesmo
# valor no work.colab quando o agente lá consumir este MCP.
MCP_SHARED_TOKEN=

# Anthropic (agente autónomo da Colab — server-side, não dos users)
ANTHROPIC_API_KEY=

# work.colab MCP — para o agente autónomo daqui criar drafts de tarefas no dashboard
WORKCOLAB_MCP_URL=
WORKCOLAB_MCP_TOKEN=

# Embedding provider (Fase 2)
VOYAGE_API_KEY=

# Channel credentials — preencher em Fase 1 (Shopify) e Fase 2 (resto)
# Cada empresa tem credenciais próprias, geralmente guardadas em
# marketing_sources do work.colab. Aqui usamos chaves master ou
# fazemos fetch via service-role do work.colab.
